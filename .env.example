# GuildPass Frontend — Environment Variables
# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local to source control.

# ── Mock / Demo Mode ──────────────────────────────────────────────────────────
# Set to "true" to use the in-memory mock API (no backend required)
NEXT_PUBLIC_MOCK_MODE=true

# ── Live Mode ─────────────────────────────────────────────────────────────────
# Base URL of the running guildpass-core access-api
# Only required when NEXT_PUBLIC_MOCK_MODE is not "true"
NEXT_PUBLIC_CORE_API_URL=http://localhost:3000
